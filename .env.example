# Wildberries API Token (read-only recommended for HTTP deployments)
# Получите токен в ЛК продавца: Настройки → API → Создать новый токен
WB_API_TOKEN=your_wildberries_api_token_here

# Transport: stdio (default) | http
# MCP_TRANSPORT=http

# Required when MCP_TRANSPORT=http — shared secret for Authorization: Bearer
# MCP_AUTH_TOKEN=change-me-long-random-secret

# Do not register write tools (reply_*, update_*, create_supply)
# READ_ONLY=true

# HTTP bind (Docker: 0.0.0.0). Port published only on internal network.
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp

# Extra Host headers allowed (comma-separated). localhost/127.0.0.1 always included.
# MCP_ALLOWED_HOSTS=wb-mcp
