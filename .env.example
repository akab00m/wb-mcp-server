# Wildberries API Token (read-only recommended for HTTP deployments)
# Получите токен в ЛК продавца: Настройки → API → Создать новый токен
WB_API_TOKEN=your_wildberries_api_token_here

# Transport: stdio (default outside Docker image) | http
# MCP_TRANSPORT=http

# Required when MCP_TRANSPORT=http — shared secret for Authorization: Bearer
# MCP_AUTH_TOKEN=change-me-long-random-secret

# Do not register write tools (reply_*, update_*, create_supply)
# READ_ONLY=true

# HTTP bind (Docker image defaults to 0.0.0.0). Do not publish the port to the host.
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp

# REQUIRED when MCP_HTTP_HOST is not loopback (Docker service DNS name).
# Without this, requests with Host: wb-mcp:3000 get HTTP 403.
# MCP_ALLOWED_HOSTS=wb-mcp

# Session limits (HTTP stateful mode). ~2MB RSS per session if clients reconnect without DELETE.
# MCP_SESSION_IDLE_TTL_MS=1800000
# MCP_SESSION_MAX=32
